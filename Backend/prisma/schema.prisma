generator client {
  provider = "prisma-client-js"
}

enum ExpenseStatus {
  ACTIVE
  DELETED
}

datasource db {
  provider = "mysql"
}



enum ScheduleType {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum BudgetPeriod {
  MONTHLY
  ROLLING_30
  PAYCHECK
}

enum NotificationType {
  BUDGET_WARNING
  BUDGET_EXCEEDED
}



model User {
  id             String        @id @default(uuid())
  email          String        @unique
  name           String
  passwordHash   String?       
  currency       String        @default("INR")
  timezone       String        @default("Asia/Kolkata")
  
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  expenses           Expense[]
  categories         Category[]
  budgets            Budget[]
  notifications      Notification[]
  recurringExpenses  RecurringExpense[]

  @@map("users")
}

model Category {
  id        String   @id @default(uuid())
  userId    String
  name      String
  icon      String   @default("tag")
  colorHex  String   @default("#6366f1")
  isSystem  Boolean  @default(false) 
  createdAt DateTime @default(now())

  // Relations
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses          Expense[]
  budgets           Budget[]
  recurringExpenses RecurringExpense[]

  @@unique([userId, name]) 
  @@map("categories")
}

model Expense {
  id           String        @id @default(uuid())
  userId       String
  categoryId   String
  amount       Decimal       @db.Decimal(12, 2)
  currency     String        @default("INR")
  
  amountBase   Decimal       @db.Decimal(12, 2) 
  
  description  String
  expenseDate  DateTime      @db.Date
  

  recurringId  String?       
  status       ExpenseStatus @default(ACTIVE)
  
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Relations
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category          Category          @relation(fields: [categoryId], references: [id])
  recurringExpense  RecurringExpense?  @relation(fields: [recurringId], references: [id], onDelete: SetNull)


  @@index([userId, expenseDate])
  @@index([userId, categoryId])
  @@index([userId, status])
  @@map("expenses")
}

model RecurringExpense {
  id             String       @id @default(uuid())
  userId         String
  categoryId     String
  amount         Decimal      @db.Decimal(12, 2)
  currency       String       @default("INR")
  description    String
  scheduleType   ScheduleType
  scheduleDay    Int?        
  startDate      DateTime     @db.Date
  endDate        DateTime?    @db.Date
  lastTriggered  DateTime?
  nextDueDate    DateTime     @db.Date
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())

  // Relations
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category   @relation(fields: [categoryId], references: [id])
  expenses   Expense[]  

  @@index([isActive, nextDueDate])
  @@map("recurring_expenses")
}

model Budget {
  id           String       @id @default(uuid())
  userId       String
  categoryId   String?
  limitAmount  Decimal      @db.Decimal(12, 2)
  currency     String       @default("INR")
  period       BudgetPeriod @default(MONTHLY)
  periodDay    Int?         
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([userId, categoryId]) 
  @@index([userId, isActive])
  @@map("budgets")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  message   String
  budgetId  String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}